{
    "version": 2,
    "functions": {
        "api/index.php": {
            "runtime": "vercel-php@0.7.2",
            "maxDuration": 30
        }
    },
    "rewrites": [
        {
            "source": "/((?!build/|images/|favicon.ico|robots.txt).*)",
            "destination": "/api/index.php"
        }
    ],
    "outputDirectory": "public",
    "buildCommand": "npm run build",
    "installCommand": "npm install"
}
